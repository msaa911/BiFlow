
# Supabase Configuration
SUPABASE_URL=YOUR_SUPABASE_URL
SUPABASE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Database Connection (Optional if using Supabase client only, but good for direct PG)
DB_CONNECTION_STRING=postgresql://postgres:[PASSWORD]@[HOST]:[PORT]/postgres

# OpenAI Configuration (CashFlow Advisor)
# Requerido para el funcionamiento del CFO Algorítmico y recomendaciones IA
OPENAI_API_KEY=tu_clave_de_openai_aqui

# Payment Gateways (Sprint 8: Subscription Management)
# Mercado Pago (Argentina - Local Payments)
MERCADOPAGO_ACCESS_TOKEN=tu_access_token_de_mercadopago_aqui
MERCADOPAGO_WEBHOOK_SECRET=tu_secreto_de_webhook_mp_aqui

# Stripe (International - Pro/Premium Tiers)
STRIPE_SECRET_KEY=tu_stripe_secret_key_aqui
STRIPE_WEBHOOK_SECRET=tu_stripe_webhook_secret_aqui
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=tu_stripe_publishable_key_aqui

# PayPal (International - Global Support)
# Se apoya en el servidor MCP para interactuar con el dashboard de PayPal.
PAYPAL_CLIENT_ID=tu_paypal_client_id_aqui
PAYPAL_CLIENT_SECRET=tu_paypal_client_secret_aqui
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com # Usar https://api-m.paypal.com para producción
